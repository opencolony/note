{
  "name": "@opencolony/colonydoc",
  "version": "1.0.0-alpha.2",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "description": "Markdown online editor with real-time preview and LaTeX support",
  "keywords": [
    "markdown",
    "editor",
    "latex",
    "real-time",
    "cli",
    "document"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "岳晓亮 <hi@yuexiaoliang.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opencolony/colonydoc.git"
  },
  "type": "module",
  "bin": {
    "colonydoc": "./bin/colonydoc.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/dev.ts",
    "dev:frontend": "vite",
    "dev:backend": "tsx src/server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@milkdown/crepe": "^7.19.0",
    "@milkdown/plugin-listener": "^7.19.0",
    "@milkdown/prose": "^7.19.0",
    "@milkdown/react": "^7.19.0",
    "@milkdown/utils": "^7.19.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tiptap/extension-code-block-lowlight": "^3.20.4",
    "@tiptap/extension-highlight": "^3.20.4",
    "@tiptap/extension-image": "^3.20.4",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/extension-table": "^3.20.4",
    "@tiptap/extension-table-cell": "^3.20.4",
    "@tiptap/extension-table-header": "^3.20.4",
    "@tiptap/extension-table-row": "^3.20.4",
    "@tiptap/extension-task-item": "^3.20.4",
    "@tiptap/extension-task-list": "^3.20.4",
    "@tiptap/extension-typography": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "flexsearch": "^0.8.212",
    "hono": "^4.6.14",
    "katex": "^0.16.38",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-zoom-pan-pinch": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tiptap-markdown": "^0.9.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "bumpp": "^11.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "packageManager": "pnpm@9.15.4"
}
