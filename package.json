{
  "name": "colonydoc",
  "version": "0.0.0",
  "description": "Markdown online editor with real-time preview, Mermaid diagrams, and LaTeX support",
  "keywords": [
    "markdown",
    "editor",
    "mermaid",
    "latex",
    "real-time",
    "cli",
    "document"
  ],
  "license": "MIT",
  "author": "岳晓亮 <hi@yuexiaoliang.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opencolony/colonydoc.git"
  },
  "type": "module",
  "bin": {
    "colonydoc": "./bin/colonydoc.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/dev.ts",
    "dev:frontend": "vite",
    "dev:backend": "tsx src/server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ant-design/x": "^2.4.0",
    "@ant-design/x-markdown": "^2.3.0",
    "@hono/node-server": "^1.13.7",
    "antd-mobile": "^5.39.0",
    "chokidar": "^4.0.3",
    "hono": "^4.6.14",
    "mermaid": "^11.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "bumpp": "^11.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
