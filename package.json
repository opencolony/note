{
  "name": "colonydoc",
  "version": "0.0.0",
  "description": "Markdown online editor with real-time preview and LaTeX support",
  "keywords": [
    "markdown",
    "editor",
    "latex",
    "real-time",
    "cli",
    "document"
  ],
  "license": "MIT",
  "author": "岳晓亮 <hi@yuexiaoliang.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opencolony/colonydoc.git"
  },
  "type": "module",
  "bin": {
    "colonydoc": "./bin/colonydoc.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/dev.ts",
    "dev:frontend": "vite",
    "dev:backend": "tsx src/server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@milkdown/crepe": "^7.19.0",
    "@milkdown/plugin-listener": "^7.19.0",
    "@milkdown/prose": "^7.19.0",
    "@milkdown/react": "^7.19.0",
    "@milkdown/utils": "^7.19.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.6.14",
    "katex": "^0.16.38",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "bumpp": "^11.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
